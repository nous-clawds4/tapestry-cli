FROM node:22-slim

RUN apt-get update && apt-get install -y git && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy package files first for layer caching
COPY package*.json ./
RUN npm ci --production 2>/dev/null || echo "No package.json yet — skeleton container"

COPY . .

EXPOSE 3000
CMD ["node", "index.js"]
